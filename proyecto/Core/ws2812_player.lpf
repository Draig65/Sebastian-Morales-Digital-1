BLOCK RESETPATHS;
BLOCK ASYNCPATHS;
LOCATE COMP    "clk" SITE "P6";
IOBUF PORT     "clk" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk" 25.0 MHz;
LOCATE COMP    "reset_n" SITE "R7";
IOBUF PORT     "reset_n" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
LOCATE COMP    "ws_data" SITE "G5";
IOBUF PORT     "ws_data" IO_TYPE=LVCMOS33 DRIVE=8;
