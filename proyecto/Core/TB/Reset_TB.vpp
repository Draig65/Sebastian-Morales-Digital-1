#! /usr/bin/vvp
:ivl_version "13.0 (stable)" "(v13_0-dirty)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/ivl/system.vpi";
:vpi_module "/usr/lib/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/ivl/va_math.vpi";
S_0x55ff24548030 .scope module, "Reset_TB" "Reset_TB" 2 3;
 .timescale -9 -12;
v0x55ff245632e0_0 .var "clk", 0 0;
v0x55ff24563380_0 .var/i "i", 31 0;
v0x55ff24563440_0 .var "reset_n", 0 0;
v0x55ff245634e0_0 .net "rst", 0 0, L_0x55ff2450ad60;  1 drivers
E_0x55ff2454cf10 .event posedge, v0x55ff2450ae70_0;
E_0x55ff2454d160 .event negedge, v0x55ff2450ae70_0;
S_0x55ff245481c0 .scope module, "uut" "reset_ws" 2 9, 3 1 0, S_0x55ff24548030;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "reset_n";
    .port_info 2 /OUTPUT 1 "rst";
L_0x55ff2450ad60 .functor NOT 1, L_0x55ff24563580, C4<0>, C4<0>, C4<0>;
v0x55ff24509b40_0 .net *"_ivl_1", 0 0, L_0x55ff24563580;  1 drivers
v0x55ff2450ae70_0 .net "clk", 0 0, v0x55ff245632e0_0;  1 drivers
v0x55ff2450b520_0 .net "reset_n", 0 0, v0x55ff24563440_0;  1 drivers
v0x55ff2450c400_0 .var "reset_sync", 1 0;
v0x55ff24563150_0 .net "rst", 0 0, L_0x55ff2450ad60;  alias, 1 drivers
E_0x55ff2454ca60/0 .event negedge, v0x55ff2450b520_0;
E_0x55ff2454ca60/1 .event posedge, v0x55ff2450ae70_0;
E_0x55ff2454ca60 .event/or E_0x55ff2454ca60/0, E_0x55ff2454ca60/1;
L_0x55ff24563580 .part v0x55ff2450c400_0, 1, 1;
    .scope S_0x55ff245481c0;
T_0 ;
    %pushi/vec4 0, 0, 2;
    %store/vec4 v0x55ff2450c400_0, 0, 2;
    %end;
    .thread T_0;
    .scope S_0x55ff245481c0;
T_1 ;
    %wait E_0x55ff2454ca60;
    %load/vec4 v0x55ff2450b520_0;
    %nor/r;
    %flag_set/vec4 8;
    %jmp/0xz  T_1.0, 8;
    %pushi/vec4 0, 0, 2;
    %assign/vec4 v0x55ff2450c400_0, 0;
    %jmp T_1.1;
T_1.0 ;
    %load/vec4 v0x55ff2450c400_0;
    %parti/s 1, 0, 2;
    %concati/vec4 1, 0, 1;
    %assign/vec4 v0x55ff2450c400_0, 0;
T_1.1 ;
    %jmp T_1;
    .thread T_1;
    .scope S_0x55ff24548030;
T_2 ;
    %delay 20000, 0;
    %load/vec4 v0x55ff245632e0_0;
    %inv;
    %store/vec4 v0x55ff245632e0_0, 0, 1;
    %jmp T_2;
    .thread T_2;
    .scope S_0x55ff24548030;
T_3 ;
    %vpi_call 2 14 "$dumpfile", "TB/Reset_TB.vcd" {0 0 0};
    %vpi_call 2 15 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x55ff24548030 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ff245632e0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ff24563440_0, 0, 1;
    %delay 1000, 0;
    %load/vec4 v0x55ff245634e0_0;
    %pad/u 32;
    %cmpi/ne 1, 0, 32;
    %jmp/0xz  T_3.0, 6;
    %vpi_call 2 23 "$display", "Reset_TB FAIL: no arranca reseteado" {0 0 0};
    %vpi_call 2 24 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
T_3.0 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x55ff24563380_0, 0, 32;
T_3.2 ; Top of for-loop
    %load/vec4 v0x55ff24563380_0;
    %cmpi/s 3, 0, 32;
	  %jmp/0xz T_3.3, 5;
    %wait E_0x55ff2454cf10;
    %delay 1000, 0;
    %load/vec4 v0x55ff245634e0_0;
    %pad/u 32;
    %cmpi/ne 1, 0, 32;
    %jmp/0xz  T_3.5, 6;
    %vpi_call 2 31 "$display", "Reset_TB FAIL: rst cayo con reset_n en bajo" {0 0 0};
    %vpi_call 2 32 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
T_3.5 ;
T_3.4 ; for-loop step statement
    %load/vec4 v0x55ff24563380_0;
    %addi 1, 0, 32;
    %store/vec4 v0x55ff24563380_0, 0, 32;
    %jmp T_3.2;
T_3.3 ; for-loop exit label
    %wait E_0x55ff2454d160;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55ff24563440_0, 0, 1;
    %wait E_0x55ff2454cf10;
    %delay 1000, 0;
    %load/vec4 v0x55ff245634e0_0;
    %pad/u 32;
    %cmpi/ne 1, 0, 32;
    %jmp/0xz  T_3.7, 6;
    %vpi_call 2 41 "$display", "Reset_TB FAIL: solto el reset en 1 flanco (deben ser 2)" {0 0 0};
    %vpi_call 2 42 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
T_3.7 ;
    %wait E_0x55ff2454cf10;
    %delay 1000, 0;
    %load/vec4 v0x55ff245634e0_0;
    %pad/u 32;
    %cmpi/ne 0, 0, 32;
    %jmp/0xz  T_3.9, 6;
    %vpi_call 2 46 "$display", "Reset_TB FAIL: no solto el reset en 2 flancos" {0 0 0};
    %vpi_call 2 47 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
T_3.9 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x55ff24563380_0, 0, 32;
T_3.11 ; Top of for-loop
    %load/vec4 v0x55ff24563380_0;
    %cmpi/s 3, 0, 32;
	  %jmp/0xz T_3.12, 5;
    %wait E_0x55ff2454cf10;
    %delay 1000, 0;
    %load/vec4 v0x55ff245634e0_0;
    %pad/u 32;
    %cmpi/ne 0, 0, 32;
    %jmp/0xz  T_3.14, 6;
    %vpi_call 2 52 "$display", "Reset_TB FAIL: rst rebota tras liberarse" {0 0 0};
    %vpi_call 2 53 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
T_3.14 ;
T_3.13 ; for-loop step statement
    %load/vec4 v0x55ff24563380_0;
    %addi 1, 0, 32;
    %store/vec4 v0x55ff24563380_0, 0, 32;
    %jmp T_3.11;
T_3.12 ; for-loop exit label
    %wait E_0x55ff2454cf10;
    %delay 7000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ff24563440_0, 0, 1;
    %delay 1000, 0;
    %load/vec4 v0x55ff245634e0_0;
    %pad/u 32;
    %cmpi/ne 1, 0, 32;
    %jmp/0xz  T_3.16, 6;
    %vpi_call 2 63 "$display", "Reset_TB FAIL: el reset no entro asincronicamente" {0 0 0};
    %vpi_call 2 64 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
T_3.16 ;
    %vpi_call 2 67 "$display", "Reset_TB PASS: arranque reseteado, liberacion en 2 flancos y entrada asincrona" {0 0 0};
    %vpi_call 2 68 "$finish" {0 0 0};
    %end;
    .thread T_3;
    .scope S_0x55ff24548030;
T_4 ;
    %delay 100000000, 0;
    %vpi_call 2 73 "$display", "Reset_TB FAIL: timeout" {0 0 0};
    %vpi_call 2 74 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
    %end;
    .thread T_4;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "TB/Reset_TB.v";
    "Reset.v";
